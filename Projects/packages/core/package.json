{
    "name": "@neonflux/core",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./dist/index.js"
        },
        "./logging": {
            "types": "./src/logging/logger.ts",
            "import": "./dist/logging/logger.js"
        },
        "./mode": {
            "types": "./src/mode.ts",
            "import": "./dist/mode.js"
        },
        "./defcon": {
            "types": "./src/defcon.ts",
            "import": "./dist/defcon.js"
        },
        "./feature-catalog": {
            "types": "./src/feature-catalog.ts",
            "import": "./dist/feature-catalog.js"
        },
        "./command-prefix": {
            "types": "./src/command-prefix.ts",
            "import": "./dist/command-prefix.js"
        },
        "./public-url": {
            "types": "./src/public-url.ts",
            "import": "./dist/public-url.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "evlog": "^2.19.1",
        "neverthrow": "^8.2.0"
    },
    "devDependencies": {
        "@neonflux/config": "workspace:*"
    }
}
