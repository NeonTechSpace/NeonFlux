{
    "name": "@neonflux/fluxer",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./dist/index.js"
        },
        "./oauth": {
            "types": "./src/oauth.ts",
            "import": "./dist/oauth.js"
        },
        "./permissions": {
            "types": "./src/permissions.ts",
            "import": "./dist/permissions.js"
        },
        "./users": {
            "types": "./src/users.ts",
            "import": "./dist/users.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@fluxerjs/core": "^1.3.1",
        "@neonflux/core": "workspace:*",
        "neverthrow": "^8.2.0"
    },
    "devDependencies": {
        "@neonflux/config": "workspace:*"
    }
}
