{
    "name": "@neonflux/db",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./dist/index.js"
        },
        "./schema": {
            "types": "./src/schema.ts",
            "import": "./dist/schema.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "drizzle-orm": "^0.45.2",
        "neverthrow": "^8.2.0",
        "pg": "^8.21.0"
    },
    "devDependencies": {
        "@electric-sql/pglite": "^0.5.3"
    }
}
