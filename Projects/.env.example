# Same key names are used for local and deployed runs; only the values change.

# Docker image tags used by docker-compose.yml.
NEONFLUX_BOT_IMAGE_TAG=latest
NEONFLUX_WEB_IMAGE_TAG=latest

# Host port for the web service in Docker Compose.
WEB_PORT=3000

# App runtime for direct local commands. Docker Compose hardcodes production for app containers.
APP_ENV=development

# Node/runtime environment for direct local commands. Docker Compose hardcodes production for app containers.
NODE_ENV=development

# Bot bootstrap mode. Bot writes this into deployment_config; web reads the DB row.
INSTANCE_MODE=multi

# Required only when INSTANCE_MODE=single. Bot writes this into deployment_config; web reads the DB row.
SINGLE_GUILD_ID=

# Public browser-facing origin. Bot writes this into deployment_config; app code owns paths.
# Example: https://neonflux.example
PUBLIC_WEB_URL=

# Run pending DB migrations on bot/web startup. Uses a Postgres lock so only one service migrates.
AUTO_MIGRATE=true

# Guild safety override checked before DB policy.
# auto: dev is DEFCON 2 by default, prod uses DB/default DEFCON 3.
# Use 3 locally when you intentionally want to unlock dev.
# 1: emergency owner-only command/dashboard mode.
# 2: public commands work, guarded commands/dashboard settings are owner-only.
# 3: normal mode.
GUILD_DEFCON_OVERRIDE=auto

# Postgres connection string used by bot, web, and migrations.
# Docker Compose / Portainer should use the db service name:
DATABASE_URL=postgres://neonflux:change-me@db:5432/neonflux
# Direct local smoke tests can use a hosted Neon URL or any other reachable Postgres.
# Local checks that do not run bot/web against the DB do not need local Postgres.

# Docker Compose Postgres service values. Not read by the app directly.
POSTGRES_USER=neonflux
POSTGRES_PASSWORD=change-me
POSTGRES_DB=neonflux

# Fluxer application id for the current environment.
FLUXER_APP_ID=

# Fluxer OAuth client secret. Server-side only.
FLUXER_CLIENT_SECRET=

# Fluxer bot token. Server-side only.
FLUXER_BOT_TOKEN=

# OAuth callback URL registered in the Fluxer application.
# Local dev usually uses localhost. Production should use the public HTTPS web URL.
FLUXER_OAUTH_REDIRECT_URL=http://localhost:3000/auth/fluxer/callback

# Secret used to sign web sessions. Generate with: pnpm generate:session-secret
SESSION_SECRET=

# Separate key used to encrypt stored Fluxer OAuth tokens. Generate with: pnpm generate:token-encryption-key
FLUXER_TOKEN_ENCRYPTION_KEY=

# Logging verbosity.
LOG_LEVEL=info

# Comma-separated Fluxer user ids. Bot writes these into deployment_config; web reads the DB row.
OWNER_IDS=
