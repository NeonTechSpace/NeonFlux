# Same key names are used for local and deployed runs; only the values change.

# App runtime. Use development locally, production in deployment.
APP_ENV=development

# Bot install mode. single targets one guild, multi serves all installed guilds.
INSTANCE_MODE=multi

# Required only when INSTANCE_MODE=single. Leave empty for multi.
SINGLE_GUILD_ID=

# Run pending DB migrations on bot/web startup. Uses a Postgres lock so only one service migrates.
AUTO_MIGRATE=true

# Postgres connection string used by bot, web, and migrations.
# Local non-Docker dev usually uses localhost:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/neonflux_dev
# Docker Compose / Portainer should use the db service name instead:
# DATABASE_URL=postgres://neonflux:change-me@db:5432/neonflux

# Docker Compose Postgres service values. Not read by the app directly.
POSTGRES_USER=neonflux
POSTGRES_PASSWORD=change-me
POSTGRES_DB=neonflux

# Fluxer application id for the current environment.
FLUXER_APP_ID=

# Fluxer OAuth client secret. Server-side only.
FLUXER_CLIENT_SECRET=

# Fluxer bot token. Server-side only.
FLUXER_BOT_TOKEN=

# OAuth callback URL registered in the Fluxer application.
# Local dev usually uses localhost. Production should use the public HTTPS web URL.
FLUXER_OAUTH_REDIRECT_URL=http://localhost:3000/auth/fluxer/callback

# Secret used to sign web sessions. Generate with: pnpm generate:session-secret
SESSION_SECRET=

# Logging verbosity.
LOG_LEVEL=info

# Node/tooling environment. Usually development locally and production in deployment.
NODE_ENV=development

# Comma-separated Fluxer user ids with owner-only access.
OWNER_IDS=
